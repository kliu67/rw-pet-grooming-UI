{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared-api": ["../../packages/shared-api/src"],
      "@shared-api/*": ["../../packages/shared-api/src/*"],
      "@shared-utils": ["../../packages/shared-utils/src"],
      "@shared-utils/*": ["../../packages/shared-utils/src/*"]
    },
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}
